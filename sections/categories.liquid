<section class="section">
  <div class="section-inner">

    <div class="section-header">
      <div>
        <div class="section-label">{{ section.settings.label | default: 'Explora por categoría' }}</div>
        <h2 class="section-title">{{ section.settings.title | default: 'Categorías Principales' }}</h2>
      </div>
    </div>

    <div class="categories-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.url }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-icon">{{ block.settings.icon }}</div>
          <div class="category-name">{{ block.settings.name }}</div>
          <div class="category-count">{{ block.settings.count }}</div>
        </a>
      {% else %}
        {% assign default_cats = 'procesadores,tarjetas-de-video,memorias-ram,almacenamiento,placas-madre,fuentes-de-poder,software,perifericos,redes' | split: ',' %}
        {% assign default_icons = '⚡,🎮,🧠,💾,🔌,🔋,💿,🖱️,📡' | split: ',' %}
        {% assign default_names = 'Procesadores,Tarjetas de Video,Memorias RAM,Almacenamiento,Placas Madre,Fuentes de Poder,Software,Periféricos,Redes' | split: ',' %}
        {% assign default_subs  = 'Intel & AMD,NVIDIA & AMD,DDR4 & DDR5,SSD & HDD,AM5 & LGA,80 Plus,Licencias originales,Mouse & Teclado,Routers & Switches' | split: ',' %}
        {% for handle in default_cats %}
          {% assign col = collections[handle] %}
          {% assign col_url = col.url | default: routes.all_products_collection_url %}
          <a href="{{ col_url }}" class="category-card">
            <div class="category-icon">{{ default_icons[forloop.index0] }}</div>
            <div class="category-name">{{ default_names[forloop.index0] }}</div>
            <div class="category-count">{{ default_subs[forloop.index0] }}</div>
          </a>
        {% endfor %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Categorías",
  "settings": [
    { "type": "text", "id": "label",  "label": "Etiqueta superior", "default": "Explora por categoría" },
    { "type": "text", "id": "title",  "label": "Título de sección",  "default": "Categorías Principales" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        { "type": "text", "id": "icon",  "label": "Emoji / Ícono", "default": "💻" },
        { "type": "text", "id": "name",  "label": "Nombre",        "default": "Categoría" },
        { "type": "text", "id": "count", "label": "Subtexto",      "default": "Ver productos" },
        { "type": "url",  "id": "url",   "label": "Enlace" }
      ]
    }
  ],
  "presets": [{ "name": "Categorías" }]
}
{% endschema %}
