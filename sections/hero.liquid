<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-inner">

    <div class="hero-content">
      <div class="hero-badge">
        ⚡ {{ section.settings.badge | default: 'Tecnología de Vanguardia' }}
      </div>

      <h1 class="hero-title">
        {{ section.settings.heading | default: 'Tu tienda de' }}
        <span class="highlight">{{ section.settings.heading_highlight | default: 'Hardware & Software' }}</span>
        {{ section.settings.heading_end | default: 'de confianza' }}
      </h1>

      <p class="hero-desc">
        {{ section.settings.subheading | default: 'Encuentra los mejores componentes de computadora, software original y hardware especializado. Precios competitivos, asesoría experta y envío rápido a todo el país.' }}
      </p>

      <div class="hero-cta">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn-primary">
          {{ section.settings.cta_text | default: 'Ver Productos' }} →
        </a>
        <a href="{{ section.settings.cta2_url | default: '/pages/soporte' }}" class="btn-secondary">
          {{ section.settings.cta2_text | default: '🛠️ Soporte Técnico' }}
        </a>
      </div>
    </div>

    <div class="hero-visual">
      {% if section.settings.hero_image != blank %}
        <img
          src="{{ section.settings.hero_image | img_url: '600x' }}"
          alt="RED SERVCOM — Hardware profesional"
          loading="eager"
          style="max-width:100%; border-radius:16px;"
        >
      {% else %}
        <div class="hero-card-stack">
          <div class="hero-card hero-card-back">
            <div style="font-size:2rem;margin-bottom:8px;">🖥️</div>
            <div style="font-size:0.8rem;color:var(--color-text-muted);">Procesadores Intel & AMD</div>
          </div>
          <div class="hero-card hero-card-main">
            <div style="font-size:2.5rem;margin-bottom:12px;">⚡</div>
            <div style="font-weight:700;font-size:0.95rem;margin-bottom:4px;">RTX 4070 SUPER</div>
            <div style="color:var(--color-primary);font-weight:800;font-size:1.2rem;">S/3,499</div>
            <div style="font-size:0.75rem;color:var(--color-text-muted);margin-top:4px;">12GB GDDR6X · DLSS 3</div>
          </div>
        </div>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Hero Principal",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Texto del badge",
      "default": "Tecnología de Vanguardia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título (parte 1)",
      "default": "Tu tienda de"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Título (parte destacada)",
      "default": "Hardware & Software"
    },
    {
      "type": "text",
      "id": "heading_end",
      "label": "Título (parte final)",
      "default": "de confianza"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Descripción",
      "default": "Encuentra los mejores componentes de computadora, software original y hardware especializado. Precios competitivos, asesoría experta y envío rápido a todo el país."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto botón principal",
      "default": "Ver Productos"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL botón principal"
    },
    {
      "type": "text",
      "id": "cta2_text",
      "label": "Texto botón secundario",
      "default": "🛠️ Soporte Técnico"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "URL botón secundario"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Imagen del hero"
    }
  ],
  "presets": [{ "name": "Hero Principal" }]
}
{% endschema %}
