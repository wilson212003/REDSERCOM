    <!-- ═══ TAB: MANTENIMIENTO ═══ -->
    <div class="tab-panel" id="tab-mantenimiento">

      <div style="margin-bottom:40px;">
        <div class="section-label" style="margin-bottom:6px;">Planes disponibles</div>
        <h2 class="section-title" style="margin-bottom:8px;">Mantenimiento Preventivo y Correctivo</h2>
        <p style="color:var(--color-text-muted);font-size:0.88rem;max-width:600px;margin-bottom:32px;">
          El mantenimiento regular prolonga la vida útil de tu equipo, mejora el rendimiento y previene fallas costosas. Contamos con planes para uso personal, empresarial y gaming.
        </p>

        <!-- Planes de mantenimiento -->
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-bottom:40px;">

          <!-- Plan Básico -->
          <div class="support-card" style="border-color:var(--color-border);">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
