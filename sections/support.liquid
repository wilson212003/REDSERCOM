<script>
function toggleFaq(id) {
  var item = document.getElementById(id);
  var isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(function(el) { el.classList.remove('open'); });
  if (!isOpen) item.classList.add('open');
}

document.querySelectorAll('.tab-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var tabId = this.dataset.tab;
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
    this.classList.add('active');
    document.getElementById('tab-' + tabId).classList.add('active');
    window.scrollTo({ top: document.querySelector('.support-hero').offsetTop - 80, behavior: 'smooth' });
  });
});
</script>

{% schema %}
{
  "name": "Soporte Técnico",
  "settings": [
    { "type": "text",     "id": "label",     "label": "Etiqueta hero",  "default": "Estamos para ayudarte" },
    { "type": "text",     "id": "heading",   "label": "Título hero",    "default": "Soporte Técnico" },
    { "type": "textarea", "id": "subheading","label": "Subtítulo",      "default": "Contamos con técnicos certificados para resolver cualquier problema de hardware, software o mantenimiento de tu equipo." },
    { "type": "text",     "id": "phone",     "label": "Teléfono",       "default": "+51 999 999 999" },
    { "type": "text",     "id": "whatsapp",  "label": "WhatsApp (número con código país, ej: 51999999999)" }
  ],
  "presets": [{ "name": "Soporte Técnico" }]
}
{% endschema %}
