<style>
/* ── SUPPORT HERO ── */
.support-hero {
  background: linear-gradient(135deg, #05080f 0%, #0d1526 60%, #1a0a0a 100%);
  padding: 64px 24px 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.support-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 120%, rgba(230,57,70,0.12) 0%, transparent 60%);
}

.support-hero-inner { position: relative; z-index: 1; }

/* ── TABS ── */
.support-tabs {
  display: flex;
  justify-content: center;
  gap: 0;
  margin-top: 40px;
  border-bottom: 2px solid var(--color-border);
  overflow-x: auto;
  scrollbar-width: none;
}

.support-tabs::-webkit-scrollbar { display: none; }

.tab-btn {
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  margin-bottom: -2px;
  padding: 14px 28px;
  color: var(--color-text-muted);
  font-size: 0.9rem;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  transition: all 0.2s;
  font-family: var(--font-body);
  letter-spacing: 0.3px;
}

.tab-btn:hover { color: var(--color-text); }

.tab-btn.active {
  color: var(--color-primary);
  border-bottom-color: var(--color-primary);
}

/* ── TAB PANELS ── */
.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* ── SUPPORT CARDS ── */
.support-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 14px;
  padding: 28px;
  transition: all 0.2s;
}

.support-card:hover {
  border-color: rgba(230,57,70,0.35);
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.4);
}

.support-card-icon {
  width: 54px;
  height: 54px;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  margin-bottom: 16px;
}

.support-card-title {
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 700;
  margin-bottom: 8px;
}

.support-card-desc {
  color: var(--color-text-muted);
  font-size: 0.83rem;
  line-height: 1.7;
  margin-bottom: 16px;
}

.support-card-price {
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--color-primary);
  margin-bottom: 16px;
}

/* ── STEPS ── */
.steps-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
}

.steps-list::before {
  content: '';
  position: absolute;
  left: 21px;
  top: 44px;
  bottom: 44px;
  width: 2px;
  background: linear-gradient(to bottom, var(--color-primary), transparent);
}

.step-item {
  display: flex;
  gap: 20px;
  align-items: flex-start;
  padding: 20px 0;
}

.step-num {
  width: 44px;
  height: 44px;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 0.9rem;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.step-content-title {
  font-weight: 700;
  font-size: 0.95rem;
  margin-bottom: 4px;
}

.step-content-desc {
  color: var(--color-text-muted);
  font-size: 0.82rem;
  line-height: 1.7;
}

/* ── FAQ ── */
.faq-item {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 10px;
  margin-bottom: 10px;
  overflow: hidden;
}

.faq-question {
  width: 100%;
  background: none;
  border: none;
  padding: 18px 20px;
  color: var(--color-text);
  font-size: 0.9rem;
  font-weight: 600;
  text-align: left;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  font-family: var(--font-body);
  transition: color 0.2s;
}

.faq-question:hover { color: var(--color-primary); }

.faq-icon {
  font-size: 1.1rem;
  flex-shrink: 0;
  transition: transform 0.3s;
  color: var(--color-primary);
}

.faq-item.open .faq-icon { transform: rotate(45deg); }

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
}

.faq-item.open .faq-answer { max-height: 400px; }

.faq-answer-inner {
  padding: 0 20px 18px;
  color: var(--color-text-muted);
  font-size: 0.85rem;
  line-height: 1.8;
  border-top: 1px solid var(--color-border);
  padding-top: 14px;
}

/* ── GARANTIA BADGE ── */
.garantia-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 14px;
  border-radius: 100px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.badge-green  { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); color: #10b981; }
.badge-yellow { background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.3); color: #f59e0b; }
.badge-red    { background: rgba(230,57,70,0.12);  border: 1px solid rgba(230,57,70,0.3);  color: var(--color-primary); }

/* ── TABLE ── */
.support-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.85rem;
}

.support-table th {
  background: var(--color-bg-surface);
  padding: 12px 16px;
  text-align: left;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--color-text-muted);
  border-bottom: 1px solid var(--color-border);
}

.support-table td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text-muted);
  vertical-align: middle;
}

.support-table tr:last-child td { border-bottom: none; }
.support-table tr:hover td { background: rgba(255,255,255,0.02); }
.support-table td:first-child { color: var(--color-text); font-weight: 600; }

@media (max-width: 768px) {
  .tab-btn { padding: 12px 16px; font-size: 0.82rem; }
  .support-table { font-size: 0.78rem; }
  .support-table th, .support-table td { padding: 10px 10px; }
}
</style>

<!-- ── HERO ── -->
<div class="support-hero">
  <div class="support-hero-inner">
    <div class="section-label" style="display:flex;justify-content:center;margin-bottom:12px;">
      {{ section.settings.label | default: 'Estamos para ayudarte' }}
    </div>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3rem);font-weight:800;margin-bottom:16px;">
      {{ section.settings.heading | default: 'Soporte Técnico' }}
    </h1>
    <p style="color:var(--color-text-muted);font-size:0.95rem;max-width:520px;margin:0 auto 32px;line-height:1.8;">
      {{ section.settings.subheading | default: 'Contamos con técnicos certificados para resolver cualquier problema de hardware, software o mantenimiento de tu equipo.' }}
    </p>

    <!-- Quick contact chips -->
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-bottom:0;">
      {% if section.settings.whatsapp != blank %}
      <a href="https://wa.me/{{ section.settings.whatsapp }}?text=Hola%2C%20necesito%20soporte%20técnico." class="btn-primary" style="font-size:0.85rem;padding:10px 20px;" target="_blank">
        💬 WhatsApp
      </a>
      {% endif %}
      {% if section.settings.phone != blank %}
      <a href="tel:{{ section.settings.phone }}" class="btn-secondary" style="font-size:0.85rem;padding:10px 20px;">
        📞 {{ section.settings.phone }}
      </a>
      {% endif %}
      <a href="{{ routes.root_url }}pages/contactanos" class="btn-secondary" style="font-size:0.85rem;padding:10px 20px;">
        ✉️ Enviar mensaje
      </a>
    </div>
  </div>

  <!-- TABS -->
  <div class="support-tabs" id="supportTabs">
    <button class="tab-btn active" data-tab="general">🛠️ Soporte General</button>
    <button class="tab-btn" data-tab="mantenimiento">🔧 Mantenimiento</button>
    <button class="tab-btn" data-tab="garantias">🛡️ Garantías</button>
    <button class="tab-btn" data-tab="faq">❓ Preguntas Frecuentes</button>
  </div>
</div>

<!-- ── CONTENT ── -->
