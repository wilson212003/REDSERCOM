<section class="section" style="background:var(--color-bg-surface);">
  <div class="section-inner">

    <div class="section-header">
      <div>
        <div class="section-label">{{ section.settings.label | default: 'Lo que dicen nuestros clientes' }}</div>
        <h2 class="section-title">{{ section.settings.title | default: 'Testimonios' }}</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">

      {% for block in section.blocks %}
        <div class="feature-card" style="display:flex;flex-direction:column;gap:16px;" {{ block.shopify_attributes }}>
          <div style="color:var(--color-warning);font-size:1rem;letter-spacing:2px;">★★★★★</div>
          <p style="color:var(--color-text-muted);font-size:0.88rem;line-height:1.8;flex:1;">
            "{{ block.settings.review }}"
          </p>
          <div style="display:flex;align-items:center;gap:12px;border-top:1px solid var(--color-border);padding-top:16px;">
            <div style="width:40px;height:40px;background:linear-gradient(135deg,var(--color-primary),var(--color-primary-dark));border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;color:#fff;flex-shrink:0;">
              {{ block.settings.name | slice: 0 }}
            </div>
            <div>
              <div style="font-weight:700;font-size:0.88rem;">{{ block.settings.name }}</div>
              <div style="font-size:0.75rem;color:var(--color-text-muted);">{{ block.settings.location }}</div>
            </div>
            {% if block.settings.verified %}
              <div style="margin-left:auto;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:var(--color-success);font-size:0.68rem;font-weight:700;padding:3px 8px;border-radius:100px;white-space:nowrap;">✓ Compra verificada</div>
            {% endif %}
          </div>
        </div>
      {% else %}
        {% assign reviews = 'Excelente servicio, recibí mi procesador en 24 horas y todo llegó en perfecto estado. Definitivamente volvería a comprar.|Muy buena atención, me asesoraron para armar mi PC gaming sin salirme del presupuesto. Los recomiendo 100%.|Compré una licencia de Windows y la activación fue inmediata. Proceso muy sencillo y rápido. Gracias RED SERVCOM.' | split: '|' %}
        {% assign names = 'Carlos M.|Laura G.|Diego R.' | split: '|' %}
        {% assign locs  = 'Ciudad de México|Guadalajara|Monterrey' | split: '|' %}
        {% for review in reviews %}
          <div class="feature-card" style="display:flex;flex-direction:column;gap:16px;">
            <div style="color:var(--color-warning);font-size:1rem;letter-spacing:2px;">★★★★★</div>
            <p style="color:var(--color-text-muted);font-size:0.88rem;line-height:1.8;flex:1;">"{{ review }}"</p>
            <div style="display:flex;align-items:center;gap:12px;border-top:1px solid var(--color-border);padding-top:16px;">
              <div style="width:40px;height:40px;background:linear-gradient(135deg,var(--color-primary),var(--color-primary-dark));border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;color:#fff;flex-shrink:0;">
                {{ names[forloop.index0] | slice: 0 }}
              </div>
              <div>
                <div style="font-weight:700;font-size:0.88rem;">{{ names[forloop.index0] }}</div>
                <div style="font-size:0.75rem;color:var(--color-text-muted);">{{ locs[forloop.index0] }}</div>
              </div>
              <div style="margin-left:auto;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:var(--color-success);font-size:0.68rem;font-weight:700;padding:3px 8px;border-radius:100px;white-space:nowrap;">✓ Verificado</div>
            </div>
          </div>
        {% endfor %}
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonios",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta", "default": "Lo que dicen nuestros clientes" },
    { "type": "text", "id": "title", "label": "Título",   "default": "Testimonios" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Reseña",
      "settings": [
        { "type": "textarea", "id": "review",   "label": "Reseña",     "default": "Excelente servicio y envío rápido." },
        { "type": "text",     "id": "name",     "label": "Nombre",     "default": "Cliente" },
        { "type": "text",     "id": "location", "label": "Ciudad",     "default": "México" },
        { "type": "checkbox", "id": "verified", "label": "Verificado", "default": true }
      ]
    }
  ],
  "presets": [{ "name": "Testimonios" }]
}
{% endschema %}
