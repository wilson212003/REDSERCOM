<nav class="main-nav" role="navigation" aria-label="Navegación principal">
  <div class="nav-inner">

    {% if section.settings.menu != blank %}
      {% assign nav_menu = linklists[section.settings.menu] %}
      {% for link in nav_menu.links %}
        <a href="{{ link.url }}" class="nav-link {% if link.active %}active{% endif %}">
          {{ link.title }}
        </a>
      {% endfor %}
    {% else %}
      {% assign all_url = routes.all_products_collection_url %}
      <a href="{{ routes.root_url }}" class="nav-link">🏠 Inicio</a>
      {% assign cats = 'procesadores,tarjetas-de-video,memorias-ram,almacenamiento,placas-madre,fuentes-de-poder,gabinetes,software,perifericos,redes' | split: ',' %}
      {% assign labels = '⚡ Procesadores,🎮 Tarjetas de Video,🧠 Memorias RAM,💾 Almacenamiento,🔌 Placas Madre,🔋 Fuentes de Poder,📦 Gabinetes,💿 Software,🖱️ Periféricos,📡 Redes' | split: ',' %}
      {% for cat in cats %}
        {% assign col = collections[cat] %}
        {% if col != blank %}
          <a href="{{ col.url }}" class="nav-link">{{ labels[forloop.index0] }}</a>
        {% else %}
          <a href="{{ all_url }}" class="nav-link">{{ labels[forloop.index0] }}</a>
        {% endif %}
      {% endfor %}
      <a href="{{ routes.root_url }}pages/soporte" class="nav-link">🛠️ Soporte</a>
    {% endif %}

  </div>
</nav>

{% schema %}
{
  "name": "Navegación Principal",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú de navegación",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
